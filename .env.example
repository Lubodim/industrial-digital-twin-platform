OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=300
OLLAMA_THINK=false
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TEMPERATURE=0.1

# xAI Grok provider
GROK_API_KEY=GROK_API_KEY
GROK_MODEL=grok-4.5
GROK_BASE_URL=https://api.x.ai/v1
GROK_TIMEOUT_SECONDS=90
GROK_MAX_OUTPUT_TOKENS=2500


# Anthropic Claude provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_TIMEOUT_SECONDS=90
ANTHROPIC_MAX_OUTPUT_TOKENS=2500

# Google Gemini provider
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_SECONDS=90
GEMINI_MAX_OUTPUT_TOKENS=2500


GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_TIMEOUT_SECONDS=90
GEMINI_CHAT_MAX_OUTPUT_TOKENS=2000
GEMINI_CHAT_TEMPERATURE=0.3

